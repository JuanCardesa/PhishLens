{
  "manifest_version": 3,
  "name": "PhishLens",
  "version": "0.1.0",
  "description": "Defensive real-time phishing risk analysis for the current page.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:8000/*"],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "PhishLens"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/dom-analyzer.js"],
      "run_at": "document_idle"
    }
  ]
}
