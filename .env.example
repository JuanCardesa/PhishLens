PHISHTANK_API_KEY=
PHISHTANK_USER_AGENT=phishtank/phishlens-demo
PHISHLENS_ALLOWED_ORIGINS=http://localhost:5173
PHISHLENS_CHROME_EXTENSION_IDS=
PHISHLENS_ENABLE_THREAT_INTEL=true
PHISHLENS_ENABLE_TLS_ANALYSIS=true
# RDAP domain-registration-age lookup (rdap.org bootstrap, no API key needed).
PHISHLENS_ENABLE_DOMAIN_AGE_LOOKUP=true
PHISHLENS_MODEL_PATH=app/models/phishlens_model.joblib
# Diagnostics expose aggregate counters. Disable or protect with a token in any
# non-localhost deployment to prevent information leakage.
PHISHLENS_ENABLE_DIAGNOSTICS=true
# Set a non-empty value to require X-Diagnostics-Token: <value> on GET /diagnostics.
PHISHLENS_DIAGNOSTICS_TOKEN=
PHISHLENS_ENABLE_RATE_LIMITING=true
PHISHLENS_ANALYZE_RATE_LIMIT=60
PHISHLENS_REPORT_RATE_LIMIT=20
PHISHLENS_RATE_LIMIT_WINDOW_SECONDS=60
# Set to true only when the backend runs behind a trusted reverse proxy (nginx,
# Caddy, AWS ALB). Enabling this on a public endpoint lets callers spoof their
# IP and bypass rate limiting.
PHISHLENS_BEHIND_PROXY=false
PHISHLENS_FEEDBACK_DB_PATH=feedback.db
# Enable only for the local demo walkthrough. Never set true in production.
PHISHLENS_ENABLE_DEMO_THREAT_SOURCE=false
